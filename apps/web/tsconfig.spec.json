{
    "extends": "./tsconfig.json",
    "compilerOptions": {
        "outDir": "../../dist/out-tsc",
        "module": "ESNext",
        "target": "ESNext",
        "esModuleInterop": true,
        "types": ["jest", "node"],
        "moduleResolution": "bundler"
    },
    "files": ["src/test-setup.ts", "../../global.d.ts"],
    "include": [
        "jest.config.ts",
        "src/**/*.test.ts",
        "src/**/*.spec.ts",
        "src/**/*.d.ts",
        "../../libs/services/src/**/*.test.ts",
        "../../libs/services/src/**/*.spec.ts",
        "../../libs/services/src/**/*.d.ts",
        "../../libs/ui/components/src/**/*.test.ts",
        "../../libs/ui/components/src/**/*.spec.ts",
        "../../libs/ui/components/src/**/*.d.ts",
        "../../libs/ui/pipes/src/**/*.test.ts",
        "../../libs/ui/pipes/src/**/*.spec.ts",
        "../../libs/ui/pipes/src/**/*.d.ts"
    ]
}
