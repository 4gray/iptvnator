            "@search",
            "@epg",
            "@persistence",
            "@settings",
            "@pwa",
            "@self-hosted"
        ],
        "criticalJourneys": [
            {
                "name": "Electron app starts and renders workspace",
                "projects": ["electron-backend-e2e"],
                "matchAnyTags": ["@critical"]
            },
            {
                "name": "Xtream portal import, browse, and cached access",
                "projects": ["web-e2e", "electron-backend-e2e"],
                "matchAnyTags": ["@xtream"]
            },
            {
                "name": "Stalker portal import and browse",
                "projects": ["web-e2e", "electron-backend-e2e"],
                "matchAnyTags": ["@stalker"]
            },
            {
                "name": "M3U import, playback, and playlist state",
                "projects": ["web-e2e", "electron-backend-e2e"],
                "matchAnyTags": ["@m3u"]
            },
            {
                "name": "Workspace search across providers",
                "projects": ["electron-backend-e2e"],
                "matchAnyTags": ["@search"]
            },
            {
                "name": "EPG rendering and source management",
                "projects": ["electron-backend-e2e"],
                "matchAnyTags": ["@epg"]
            },
            {
                "name": "Favorites, recent items, and restart persistence",
                "projects": ["electron-backend-e2e"],
